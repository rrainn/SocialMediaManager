{
	"compilerOptions": {
		"module": "commonjs",
		"moduleResolution": "node10",
		"ignoreDeprecations": "6.0",
		"lib": [
			"es2021",
			"dom"
		],
		"types": ["node", "jest"],
		"target": "es2020",
		"outDir": "dist",
		"rootDir": "./src",
		"sourceMap": true,
		"declaration": true,
		"noImplicitThis": true,
		"strict": true,
		"skipLibCheck": true
	},
	"include": [
		"./src/**/*"
	]
}
